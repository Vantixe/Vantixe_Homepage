# Copy this file to .env.local and fill in the values. .env.local is gitignored.

# Resend (https://resend.com): vantixe.com must be a verified sending domain
RESEND_API_KEY=

# Inquiry form addressing
CONTACT_FROM_EMAIL=Vantixe <contact@vantixe.com>
CONTACT_TO_EMAIL=hello@vantixe.com

# Cloudflare Turnstile (https://dash.cloudflare.com → Turnstile)
# Optional: if both are blank the form falls back to honeypot-only spam protection.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Google Tag Manager (https://tagmanager.google.com → container ID, format GTM-XXXXXXX)
# Optional: if blank, no tracking loads and the site behaves exactly as before.
# One value covers BOTH vantixe.com and vantixe.ai (same deployment).
NEXT_PUBLIC_GTM_ID=
